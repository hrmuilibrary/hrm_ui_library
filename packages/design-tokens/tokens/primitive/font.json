{
  "font": {
    "family": {
      "primary": {
        "$type": "fontFamily",
        "$value": "'Noto Sans Armenian', 'Noto Sans'",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-family-primary"
          }
        }
      },
      "secondary": {
        "$type": "fontFamily",
        "$value": "'Tahoma'",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-family-secondary"
          }
        }
      },
      "tertiary": {
        "$type": "fontFamily",
        "$value": "'Open Sans'",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-family-tertiary"
          }
        }
      }
    },
    "size": {
      "6": {
        "$type": "dimension",
        "$value": "6px",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-size-6"
          }
        }
      },
      "10": {
