      "14": {
        "$type": "dimension",
        "$value": "14px",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-size-14"
          }
        }
      },
      "16": {
        "$type": "dimension",
        "$value": "16px",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-size-16"
          }
        }
      },
      "18": {
        "$type": "dimension",
        "$value": "18px",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-size-18"
          }
        }
      },
      "20": {
        "$type": "dimension",
        "$value": "20px",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-size-20"
          }
        }
      },
      "24": {
        "$type": "dimension",
        "$value": "24px",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-size-24"
          }
        }
      },
      "32": {
        "$type": "dimension",
        "$value": "32px",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-size-32"
          }
        }
      },
      "36": {
        "$type": "dimension",
        "$value": "36px",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-size-36"
          }
        }
      },
      "40": {
        "$type": "dimension",
        "$value": "40px",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-size-40"
          }
        }
      },
      "48": {
        "$type": "dimension",
        "$value": "48px",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-size-48"
          }
        }
      },
      "64": {
        "$type": "dimension",
        "$value": "64px",
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-size-64"
          }
        }
      }
    },
    "weight": {
      "400": {
        "$type": "fontWeight",
        "$value": 400,
        "$extensions": {
          "com.hrm": {
            "cssVar": "font-weight-400"
          }
        }
      },
      "500": {
        "$type": "fontWeight",
        "$value": 500,
        "$extensions": {
