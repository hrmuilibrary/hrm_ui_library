      "lg": {
        "$type": "number",
        "$value": 1.5,
        "$extensions": {
          "com.hrm": {
            "cssVar": "line-height-lg"
          }
        }
      }
    },
    "letterSpacing": {
      "default": {
        "$type": "dimension",
        "$value": "1px",
        "$extensions": {
          "com.hrm": {
            "cssVar": "letter-spacing"
          }
        }
      }
    }
